# Plantilla de variables de entorno. Copiar a `.env` y completar valores reales.
# El archivo `.env` NUNCA se commitea (ver .gitignore).

# ---------------------------------------------------------------------------
# Bases de datos (database-per-service)
# ---------------------------------------------------------------------------

# mysql-auth (authdb)
MYSQL_AUTH_ROOT_PASSWORD=
MYSQL_AUTH_DATABASE=authdb
MYSQL_AUTH_USER=auth_user
MYSQL_AUTH_PASSWORD=

# mysql-locker (lockerdb)
MYSQL_LOCKER_ROOT_PASSWORD=
MYSQL_LOCKER_DATABASE=lockerdb
MYSQL_LOCKER_USER=locker_user
MYSQL_LOCKER_PASSWORD=

# mysql-rental (rentaldb)
MYSQL_RENTAL_ROOT_PASSWORD=
MYSQL_RENTAL_DATABASE=rentaldb
MYSQL_RENTAL_USER=rental_user
MYSQL_RENTAL_PASSWORD=

# mongo-help (helpdb)
MONGO_HELP_ROOT_USER=root
MONGO_HELP_ROOT_PASSWORD=
MONGO_HELP_DATABASE=helpdb
MONGO_HELP_USER=help_user
MONGO_HELP_PASSWORD=

# ---------------------------------------------------------------------------
# Seguridad (JWT compartido entre gateway y servicios)
# ---------------------------------------------------------------------------

JWT_SECRET=

# ---------------------------------------------------------------------------
# api-gateway
# ---------------------------------------------------------------------------

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ---------------------------------------------------------------------------
# auth-service
# ---------------------------------------------------------------------------

ADMIN_DEFAULT_PASSWORD=
FRONTEND_URL=http://localhost:5173

# SMTP (Gmail) para envío de correos de verificación y reset de clave
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# ---------------------------------------------------------------------------
# rental-service (Payphone)
# ---------------------------------------------------------------------------

PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# ---------------------------------------------------------------------------
# frontend (build-time)
# ---------------------------------------------------------------------------

VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
